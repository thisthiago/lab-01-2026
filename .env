# =============================================================
# DATA ENGINEERING STACK — Environment Variables
# =============================================================

# -------------------------
# PostgreSQL
# -------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=datawarehouse
POSTGRES_USER=dw_user
POSTGRES_PASSWORD=dw_password123

# -------------------------
# MongoDB
# -------------------------
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=source_db
MONGO_USER=mongo_user
MONGO_PASSWORD=mongo_password123
MONGO_AUTH_SOURCE=admin

# -------------------------
# Dagster
# -------------------------
DAGSTER_HOME=/opt/dagster/dagster_home
DAGSTER_POSTGRES_HOST=postgres
DAGSTER_POSTGRES_PORT=5432
DAGSTER_POSTGRES_DB=dagster
DAGSTER_POSTGRES_USER=dw_user
DAGSTER_POSTGRES_PASSWORD=dw_password123

# -------------------------
# Airbyte
# -------------------------
AIRBYTE_HOST=airbyte-server
AIRBYTE_PORT=8001
AIRBYTE_WEBAPP_PORT=8000
BASIC_AUTH_USERNAME=airbyte
BASIC_AUTH_PASSWORD=password
